<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'><head><meta charset='UTF-8'><style>body{font-family:Calibri,Arial,sans-serif;font-size:11pt;color:#1a1a1a;margin:0;padding:32px 40px;max-width:920px;line-height:1.7}
.cover{text-align:center;padding:48px 0 36px;border-bottom:3px solid #2e4d8a;margin-bottom:36px}
.cover-tag{font-size:10pt;font-weight:700;text-transform:uppercase;letter-spacing:2.5px;color:#2e4d8a;margin-bottom:8px}
.cover h1{font-size:28pt;font-weight:700;color:#1a2a4a;margin-bottom:8px}
.cover-sub{font-size:12pt;color:#555;margin-bottom:14px}
.cover-contact{font-size:10pt;color:#2e4d8a}
.doc{margin-bottom:56px;padding-bottom:40px;border-bottom:3px solid #2e4d8a;page-break-after:always}
.doc:last-of-type{border-bottom:none}
.doc-header{background:linear-gradient(135deg,#1a2a4a,#2e4d8a);color:#fff;padding:24px 28px;display:flex;align-items:center;gap:20px}
.doc-header-text{flex:1}
.doc-num{font-size:9pt;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:#9fb8d8;margin-bottom:4px}
.doc-title{font-size:16pt;font-weight:700;margin-bottom:4px}
.doc-sub{font-size:10pt;color:#b8cce0}
.doc-icon{width:64px;height:64px;flex-shrink:0}
.doc-purpose{background:#f7f9fc;border:1px solid #d5e0f0;padding:14px 18px;margin-bottom:22px;display:flex;align-items:flex-start;gap:10px}
.doc-purpose p{font-size:10pt;color:#444;margin-bottom:0}
.doc-purpose strong{color:#2e4d8a}
h3.sec{font-size:11pt;font-weight:700;color:#2e4d8a;text-transform:uppercase;letter-spacing:0.8px;margin:22px 0 10px;padding-bottom:5px;border-bottom:2px solid #e0e8f5;display:flex;align-items:center;gap:8px}
h4.sub{font-size:10.5pt;font-weight:700;color:#1a2a4a;margin:16px 0 6px}
p{font-size:10.5pt;color:#222;margin-bottom:8px}
ul{padding-left:18px;margin-bottom:8px}
li{font-size:10.5pt;margin-bottom:5px;line-height:1.5}
table{width:100%;border-collapse:collapse;margin:14px 0;font-size:10pt;border:1px solid #d5e0f0}
th{background:#1a2a4a;color:#fff;padding:10px 13px;text-align:left;font-size:9pt;font-weight:700;text-transform:uppercase}
td{padding:10px 13px;border-bottom:1px solid #e0e6ef;vertical-align:top;line-height:1.5}
tr:nth-child(even){background:#f7f9fc}
.ex{background:#f7f9fc;border:1px solid #d5e0f0;padding:14px 16px;margin:10px 0}
.ex-label{font-size:8.5pt;font-weight:700;text-transform:uppercase;color:#2e4d8a;margin-bottom:6px}
.ex p{margin-bottom:5px}
.voice-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:14px 0}
.voice-card{background:#f7f9fc;border:1px solid #d5e0f0;padding:16px;display:flex;gap:12px}
.voice-card h4{font-size:10.5pt;font-weight:700;color:#1a2a4a;margin-bottom:4px}
.voice-card p{font-size:9.5pt;color:#444;margin-bottom:3px}
.ex-do{font-size:9pt;color:#1a6b30;font-weight:600}
.ex-dont{font-size:9pt;color:#c0392b;font-weight:600}
.spectrum{display:grid;grid-template-columns:repeat(5,1fr);gap:0;margin:14px 0;border:1px solid #d5e0f0}
.spec-col{padding:14px 10px;text-align:center}
.spec-col:nth-child(1){background:#fde8e8}
.spec-col:nth-child(2){background:#fff3e0}
.spec-col:nth-child(3){background:#fefce8}
.spec-col:nth-child(4){background:#e8f5e9}
.spec-col:nth-child(5){background:#e3f2fd}
.spec-label{font-size:8pt;font-weight:700;text-transform:uppercase;margin-bottom:4px}
.spec-tone{font-size:9.5pt;font-weight:600;margin-bottom:3px}
.spec-ex{font-size:8.5pt;color:#555;line-height:1.3}
.dtree{background:#fff8e6;border:1px solid #e6d5a0;padding:16px 18px;margin:10px 0}
.dtree-q{font-size:10.5pt;font-weight:700;color:#7a4a00;margin-bottom:8px;display:flex;align-items:flex-start;gap:8px}
.dtree-branch{margin-left:20px;padding-left:16px;border-left:2px solid #e6c85a;margin-bottom:4px}
.dtree-a{font-size:10pt;color:#4a3300;margin-bottom:4px;display:flex;align-items:flex-start;gap:6px}
.dtree-yes{background:#27500A;color:#fff;font-size:8pt;font-weight:700;padding:1px 6px}
.dtree-no{background:#9a2020;color:#fff;font-size:8pt;font-weight:700;padding:1px 6px}
.dtree-result{background:#fff;border:1px solid #d5e0f0;padding:8px 12px;margin:6px 0 6px 20px;font-size:9.5pt;display:flex;align-items:flex-start;gap:6px}
.dont-list{margin:10px 0}
.dont-item{display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:1px solid #f0f0f0}
.dont-item p{font-size:10pt;color:#333;margin-bottom:0}
.ch-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin:14px 0}
.ch-card{padding:12px;text-align:center;border:1px solid #d5e0f0}
.ch-card h5{font-size:9pt;font-weight:700;margin:6px 0 4px;text-transform:uppercase}
.ch-card p{font-size:9pt;color:#555;margin-bottom:0}
.vflow{display:flex;align-items:center;justify-content:center;gap:0;margin:16px 0;flex-wrap:wrap}
.vflow-step{background:#f0f4ff;border:1px solid #c0d0f0;padding:12px 14px;text-align:center;width:100px}
.vflow-num{font-size:8pt;font-weight:700;color:#fff;background:#2e4d8a;border-radius:50%;width:22px;height:22px;display:flex;align-items:center;justify-content:center;margin:0 auto 6px}
.vflow-name{font-size:9.5pt;font-weight:700;color:#1a2a4a;margin-bottom:2px}
.vflow-detail{font-size:8pt;color:#555}
.vflow-arrow{font-size:16pt;color:#2e4d8a;margin:0 4px;font-weight:700}
.tpl{border:2px dashed #c8d8f0;padding:14px 16px;margin:10px 0;background:#fafcff;display:flex;align-items:flex-start;gap:10px}
.tpl-label{font-size:8.5pt;font-weight:700;text-transform:uppercase;color:#2e4d8a;margin-bottom:4px}
.tpl-field{font-size:10pt;color:#999;font-style:italic;line-height:1.5}
.dl-bar,.toc{display:none}
.footer{text-align:center;padding:28px 0 16px;color:#666;font-size:9.5pt;border-top:1px solid #eee;margin-top:20px}</style></head><body>

<div class="dl-bar">
  <button onclick="downloadDoc()">Download as Word Document</button>
</div>

<!-- COVER -->
<div class="cover">
  <svg width="60" height="60" viewBox="0 0 60 60" style="margin-bottom:12px"><rect x="5" y="10" width="50" height="40" rx="4" fill="none" stroke="#2e4d8a" stroke-width="2"></rect><line x1="14" y1="22" x2="46" y2="22" stroke="#2e4d8a" stroke-width="2" stroke-linecap="round"></line><line x1="14" y1="30" x2="38" y2="30" stroke="#9fb8d8" stroke-width="2" stroke-linecap="round"></line><line x1="14" y1="38" x2="42" y2="38" stroke="#9fb8d8" stroke-width="2" stroke-linecap="round"></line><circle cx="48" cy="42" r="10" fill="#2e4d8a"></circle><path d="M45 42l2.5 2.5L52 39" stroke="#fff" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"></path></svg>
  <div class="cover-tag">UX Writing Systems Toolkit</div>
  <h1>Satyajit Roy</h1>
  <div class="cover-sub">Frameworks, Templates &amp; Standards for Scalable UX Content</div>
  <div class="cover-contact">rsatyajit77@gmail.com · linkedin.com/in/rsatyajit77 · tinyurl.com/4vn84ytc</div>
</div>

<!-- TOC -->
<div class="toc">
  <h3><svg width="18" height="18" viewBox="0 0 18 18"><rect x="2" y="2" width="14" height="14" rx="2" fill="none" stroke="#2e4d8a" stroke-width="1.5"></rect><line x1="5" y1="6" x2="13" y2="6" stroke="#2e4d8a" stroke-width="1.5" stroke-linecap="round"></line><line x1="5" y1="9" x2="11" y2="9" stroke="#9fb8d8" stroke-width="1.5" stroke-linecap="round"></line><line x1="5" y1="12" x2="13" y2="12" stroke="#9fb8d8" stroke-width="1.5" stroke-linecap="round"></line></svg> Documents</h3>
